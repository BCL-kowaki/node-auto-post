# Google Gemini API（記事生成・画像生成）
GEMINI_API_KEY=

# AssemblyAI（文字起こし）
ASSEMBLYAI_API_KEY=

# Supadata（YouTube → テキスト: 字幕 + Whisper AIフォールバック）
# https://supadata.ai/ でサインアップして取得
SUPADATA_API_KEY=

# WordPress（投稿先）
WP_BASE_URL=https://your-site.com
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# アプリ設定
NEXT_PUBLIC_APP_URL=http://localhost:3000
