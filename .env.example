# Google Gemini API（記事生成・画像生成）
GEMINI_API_KEY=

# AssemblyAI（文字起こし）
ASSEMBLYAI_API_KEY=

# RapidAPI（YouTube音声抽出: youtube-mp36）
# https://rapidapi.com/ytjar/api/youtube-mp36 をSubscribe（Basic/無料）して取得
RAPIDAPI_KEY=

# WordPress（投稿先）
WP_BASE_URL=https://your-site.com
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# アプリ設定
NEXT_PUBLIC_APP_URL=http://localhost:3000
